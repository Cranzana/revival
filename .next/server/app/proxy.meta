{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(platform)/layout,_N_T_/(platform)/proxy/layout,_N_T_/(platform)/proxy/page,_N_T_/proxy"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KHBsYXRmb3JtKQ/proxy/__PAGE__",
    "/!KHBsYXRmb3JtKQ/proxy",
    "/!KHBsYXRmb3JtKQ",
    "/_index",
    "/_head"
  ]
}